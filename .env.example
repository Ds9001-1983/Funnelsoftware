# Database
DATABASE_URL=postgresql://username:password@localhost:5432/funnelflow

# Session Secret (change this in production!)
SESSION_SECRET=your-super-secret-session-key-change-in-production

# Server Port (optional, defaults to 5000)
PORT=5000

# Node Environment
NODE_ENV=development

# Admin Credentials (required for admin panel)
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_secure_password

# CSRF (optional — fällt auf SESSION_SECRET zurück)
CSRF_SECRET=

# Öffentliche App-URL (für Links in E-Mails / Redirects)
APP_URL=http://localhost:5000

# Stripe (Abo/Trial). Ohne diese ist die Bezahlung deaktiviert.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_TAX_ENABLED=false

# E-Mail (SMTP) — ohne diese werden keine Mails versendet
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@trichterwerk.de

# Monitoring (optional)
SENTRY_DSN=

# KI-Funnel-Erstellung (BYOK): Secret zur Verschlüsselung der Kunden-API-Keys.
# Optional — fällt auf SESSION_SECRET zurück. Empfohlen: eigenes 32-Byte-Secret
# (erzeugen z. B. mit: openssl rand -hex 32).
AI_ENCRYPTION_KEY=
